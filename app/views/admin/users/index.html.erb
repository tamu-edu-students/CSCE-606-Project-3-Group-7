<div class="header">
  <p>
    <%= link_to "← Back to Chat", chat_path %>
    | Logged in as <strong><%= current_user.display_name %></strong>
    | <%= link_to "Logout", logout_path, method: :delete %>
  </p>
</div>

<div class="container">
  <div class="admin-container">
    <h1>All Users (Admin)</h1>

    <% if @users.empty? %>
      <p>No users found.</p>
    <% else %>
      <table>
        <thead>
          <tr>
            <th>Email</th>
            <th>Display Name</th>
            <th>Created At</th>
            <th>Message Count</th>
            <th>
              <%= link_to admin_users_path(sort: params[:sort] == 'created_at' ? nil : 'created_at'), class: "sort-link" do %>
                Role
                <% if params[:sort] != 'created_at' %>
                  <span class="sort-indicator">▼</span>
                <% end %>
              <% end %>
            </th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= user.email %></td>
              <td><%= user.display_name %></td>
              <td><%= user.created_at.strftime('%Y-%m-%d %H:%M:%S') %></td>
              <td><%= user.messages.count %></td>
              <td><%= user.admin? ? '<span class="admin-badge">Admin</span>'.html_safe : 'User' %></td>
              <td>
                <% if user.id != current_user.id %>
                  <%= form_with url: admin_user_path(user), method: :patch, local: true, class: "inline-form" do |f| %>
                    <%= f.hidden_field :role, value: user.admin? ? "user" : "admin" %>
                    <%= f.submit user.admin? ? "Revoke Admin" : "Make Admin", class: "btn-role-toggle" %>
                  <% end %>
                <% else %>
                  <span class="text-muted">Current user</span>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% end %>
  </div>
</div>

