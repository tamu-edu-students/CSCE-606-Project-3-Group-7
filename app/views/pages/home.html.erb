<h1>Welcome to Location Chat</h1>

<% if current_user %>
  <div>
    <p>Logged in as: <%= current_user.name %></p>
    <p>Display name: <%= current_user.display_name %></p>
    <% if current_user.avatar_url %>
      <%= image_tag current_user.avatar_url, alt: current_user.name, size: "50x50" %>
    <% end %>
    <%= button_to "Logout", logout_path, method: :post %>
  </div>
<% else %>
  <%= form_with url: "/auth/google_oauth2", method: :post, data: { turbo: false } do |f| %>
    <%= link_to "Sign in with Google", "/auth/google_oauth2", method: :get %>
  <% end %>
<% end %>