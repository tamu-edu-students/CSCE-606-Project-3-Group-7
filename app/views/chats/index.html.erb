<h1>Global Chat</h1>

<p>
  Logged in as <strong><%= current_user.display_name %></strong>
  (<%= current_user.email %>)
  | <%= link_to "Logout", logout_path, method: :delete %>
  <% if current_user.is_admin? %>
    | <%= link_to "Admin Messages", admin_messages_path %>
  <% end %>
</p>

<section class="chat-container">
  <div class="chat-controls">
    <form action="<%= chat_path %>" method="get" style="display:inline">
      <button type="submit">Refresh</button>
    </form>
    <!-- Optional meta refresh: uncomment to auto-refresh every 10s (no JS) -->
    <!-- <meta http-equiv="refresh" content="10"> -->
  </div>

  <div class="messages">
    <% @messages.each do |msg| %>
      <div class="message <%= 'mine' if msg.user_id == current_user.id %>">

        <div class="meta">
          <strong><%= msg.user.display_name %></strong>
          <span class="ts"><%= msg.created_at.strftime("%Y-%m-%d %H:%M:%S") %></span>

          <% if msg.respond_to?(:distance) %>
            <span class="distance"><%= msg.distance.to_i %> m</span>
          <% end %>
        </div>

        <div class="body">
          <%= simple_format(h(msg.body)) %>
        </div>

      </div>
    <% end %>
  </div>

  <div class="composer">
    <%= form_with model: @new_message, url: messages_path, local: true do |f| %>
      <div>
        <%= f.label :body, "Message" %><br>
        <%= f.text_area :body, rows: 4, required: true %>
      </div>
      <div>
        <%= f.submit "Send" %>
      </div>
    <% end %>
  </div>
</section>
